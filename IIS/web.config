<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!-- LDAP Authentication Settings -->
    <add key="Bypass_LDAP" value="true" />
    <add key="LDAP_Names" value="SETYAZILIM;SETSOFTWARE" />
    <add key="LDAPPATH_SETYAZILIM" value="LDAP://setyazilim.com" />
    <add key="LDAPDOMAIN_SETYAZILIM" value="setyazilim" />
    <add key="LDAPPATH_SETSOFTWARE" value="LDAP://setsoftware.com" />
    <add key="LDAPDOMAIN_SETSOFTWARE" value="setsoftware" />

    <!-- LLM Model Server Endpoints Configuration -->
    <add key="LLM_Endpoints" value='[
      {"name": "Chating", "port": 8000, "model": "gemma4-26b",  "host": "172.16.1.123"},
      {"name": "Coding",  "port": 8002, "model": "qwen3.6-27b", "host": "172.16.1.123"}
    ]' />
  </appSettings>
  <system.web>
    <compilation debug="false" targetFramework="4.8" />
    <httpRuntime targetFramework="4.8" />
    <sessionState mode="InProc" timeout="60" />
    <customErrors mode="Off" />
  </system.web>
</configuration>

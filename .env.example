# =============================================================================
# DGX Spark LLM Stack — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to source control.
# =============================================================================

# ─── Domain / TLS ────────────────────────────────────────────────────────────
DOMAIN=llm.internal
ACME_EMAIL=ops@yourcompany.com

# ─── LiteLLM Gateway ─────────────────────────────────────────────────────────
# Master key for admin operations (model updates, swap, budget). Keep secret.
# Generate: openssl rand -hex 32 | sed 's/^/sk-/'
LITELLM_MASTER_KEY=sk-CHANGE_ME_LITELLM_MASTER

# ─── vLLM Backend Auth ───────────────────────────────────────────────────────
# Used by LiteLLM to authenticate against vLLM containers.
# Mirror this in secrets/vllm_key.txt (without quotes, single line).
# Generate: openssl rand -hex 32
VLLM_KEY=CHANGE_ME_VLLM_API_KEY

# ─── PostgreSQL (LiteLLM audit + cost tracking) ──────────────────────────────
PG_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# For external connection, replace this with your connection string:
# DATABASE_URL=postgresql://username:password@host:port/dbname
DATABASE_URL=postgresql://litellm:CHANGE_ME_STRONG_PASSWORD@postgres:5432/litellm

# ─── ML Server Endpoints ─────────────────────────────────────────────────────
GEMMA_MODEL_NAME=openai/gemma4-31b
GEMMA_API_BASE=http://vllm-gemma:8000/v1

QWEN_MODEL_NAME=openai/qwen-coder
QWEN_API_BASE=http://vllm-qwen3:8000/v1

REASON_MODEL_NAME=openai/gpt-oss-120b
REASON_API_BASE=http://vllm-gptoss:8000/v1

# ─── HuggingFace Token (model downloads) ─────────────────────────────────────
# Mirror in secrets/hf_token.txt
# Get from: https://huggingface.co/settings/tokens (read access sufficient)
HF_TOKEN=hf_CHANGE_ME

# ─── Grafana Admin ───────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_ADMIN

# ─── Slack Integration (optional) ────────────────────────────────────────────
# Webhook URL for swap notifications + alerts.
# Slash command signing secret used to verify incoming Slack requests.
SLACK_WEBHOOK_URL=
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# ─── Vector Store (pgvector on 172.16.0.8) ───────────────────────────────────
# External PostgreSQL server with pgvector extension
VECTOR_DB_HOST=172.16.0.8
VECTOR_DB_PORT=5432
VECTOR_DB_NAME=mydb
VECTOR_DB_USER=setadmin
VECTOR_DB_PASSWORD=CHANGE_ME_VECTOR_DB_PASSWORD
# Full connection string for SetYazilim.Llm VectorStore:
VECTOR_DB_CONNECTION_STRING=Host=172.16.0.8;Port=5432;Database=mydb;Username=setadmin;Password=CHANGE_ME_VECTOR_DB_PASSWORD;Pooling=true;Maximum Pool Size=20

# Embedding model endpoint (vllm-embed container)
EMBED_API_BASE=http://172.16.1.123:8004/v1
EMBED_API_KEY=${VLLM_KEY}
EMBED_MODEL=nomic-embed-text
EMBED_DIMENSIONS=768

# ─── Operations ──────────────────────────────────────────────────────────────
# Drain timeout (seconds) before stopping a model during swap
DRAIN_TIMEOUT=60

# Max time (seconds) to wait for a model to become healthy after start
HEALTH_TIMEOUT=600
